# ======================================================
# Git Ignore Rules
# Docs: https://help.github.com/articles/ignoring-files/
# ======================================================

# ----------------------
# Dependencies
# ----------------------
/node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----------------------
# Testing & Coverage
# ----------------------
/coverage/

# ----------------------
# Next.js
# ----------------------
/.next/
/out/
/build/

# ----------------------
# Environment & Secrets
# ----------------------
.env
.env.*
.genkit/

# ----------------------
# Logs & Debug
# ----------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
firebase-debug.log
firestore-debug.log

# ----------------------
# TypeScript
# ----------------------
*.tsbuildinfo
next-env.d.ts

# ----------------------
# Vercel
# ----------------------
.vercel

# ----------------------
# ESLint
# ----------------------
.eslintrc.json
*.eslintrc.json

# ----------------------
# PWA / Service Workers
# ----------------------
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/worker-*.js
/public/worker-*.js.map

# ======================================================
# OS GENERATED FILES (IMPORTANT)
# ======================================================

# Windows
desktop.ini
Thumbs.db
ehthumbs.db
ehthumbs_vista.db

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
