/**
 * Core Philosophy: This ruleset uses a shared collections model where purchases
 * and settlements are stored in top-level collections accessible to all authenticated
 * users. This allows teams to collaborate and see shared expenses while maintaining
 * data integrity through validation rules.
 *
 * Data Structure: The data is organized in top-level collections:
 * - /users: User profiles
 * - /purchases: All team purchases/expenses
 * - /settlements: All debt settlements
 *
 * Key Security Decisions:
 * - Shared Read Access: All authenticated users can read purchases and settlements
 *   to enable team expense tracking and balance calculations.
 * - Write Protection: Users can only create purchases with their own ID as paidById,
 *   and can only update/delete their own purchases.
 * - User Profiles: All authenticated users can read user profiles for split functionality.
 *
 * Denormalization for Authorization: Documents contain ownership fields (paidById,
 * fromId) that are validated on write to ensure data integrity and proper attribution.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for concise and readable rules.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Ensures an operation is performed by the owner on an existing document.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the user profile document being created has an 'id' field
     * that matches the document's path ID and the creator's auth UID.
     */
    function isCreatingValidUser(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Validates that a user's 'id' field remains unchanged during an update.
     */
    function isUpdatingValidUser() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that the purchase is being created by the user who paid for it.
     */
    function isCreatingValidPurchase() {
      return isSignedIn() && request.resource.data.paidById == request.auth.uid;
    }

    /**
     * Validates that the purchase is being updated by the user who paid for it,
     * and that the paidById field is not being changed.
     */
    function isUpdatingValidPurchase() {
      return isSignedIn() 
        && resource.data.paidById == request.auth.uid
        && request.resource.data.paidById == resource.data.paidById;
    }

    /**
     * Validates that the settlement is being created by the user who is making the payment.
     */
    function isCreatingValidSettlement() {
      return isSignedIn() && request.resource.data.fromId == request.auth.uid;
    }

    /**
     * Validates that the settlement is being updated by the user who paid,
     * and that the fromId field is not being changed.
     */
    function isUpdatingValidSettlement() {
      return isSignedIn()
        && resource.data.fromId == request.auth.uid
        && request.resource.data.fromId == resource.data.fromId;
    }

    /**
     * @description Rules for the User profile document.
     * @path /users/{userId}
     * @allow (read) Any authenticated user can read user profiles for split functionality.
     * @allow (create) An authenticated user creating their own user profile.
     * @allow (update/delete) Users can only modify their own profile.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isCreatingValidUser(userId);
      allow update: if isExistingOwner(userId) && isUpdatingValidUser();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for shared purchase records.
     * @path /purchases/{purchaseId}
     * @allow (read) All authenticated users can read purchases for team tracking.
     * @allow (create) Authenticated users can create purchases they paid for.
     * @allow (update/delete) Only the user who paid can update/delete their purchase.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isCreatingValidPurchase();
      allow update: if isUpdatingValidPurchase();
      allow delete: if isSignedIn() && resource.data.paidById == request.auth.uid;
    }

    /**
     * @description Rules for shared settlement records.
     * @path /settlements/{settlementId}
     * @allow (read) All authenticated users can read settlements for balance calculations.
     * @allow (create) Authenticated users can create settlements they are paying.
     * @allow (update/delete) Only the user who paid can update/delete their settlement.
     */
    match /settlements/{settlementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isCreatingValidSettlement();
      allow update: if isUpdatingValidSettlement();
      allow delete: if isSignedIn() && resource.data.fromId == request.auth.uid;
    }

    /**
     * Validates that the purchase request is being created by the authenticated user.
     */
    function isCreatingValidPurchaseRequest() {
      return isSignedIn() && request.resource.data.requestedBy == request.auth.uid;
    }

    /**
     * Validates that the purchase request is being updated by the user who created it,
     * and that the requestedBy field is not being changed.
     */
    function isUpdatingValidPurchaseRequest() {
      return isSignedIn()
        && resource.data.requestedBy == request.auth.uid
        && request.resource.data.requestedBy == resource.data.requestedBy;
    }

    /**
     * @description Rules for shared purchase request records.
     * @path /purchaseRequests/{requestId}
     * @allow (read) All authenticated users can read purchase requests for team collaboration.
     * @allow (create) Authenticated users can create purchase requests.
     * @allow (update) Only the request creator can update their request, but any authenticated
     *                 user can mark a request as 'Purchased' (status update only).
     * @allow (delete) Only the request creator can delete their request.
     */
    match /purchaseRequests/{requestId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isCreatingValidPurchaseRequest();
      allow update: if isSignedIn() && (
        // Original creator can update their request
        isUpdatingValidPurchaseRequest()
        // OR any authenticated user can mark as purchased (status field only)
        || (resource.data.requestedBy == resource.data.requestedBy 
            && request.resource.data.keys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'Purchased')
      );
      allow delete: if isSignedIn() && resource.data.requestedBy == request.auth.uid;
    }
  }
}