/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data,
 * including purchases and settlements, is stored in subcollections under a user's
 * private document. This creates a secure data silo for each user, ensuring that
 * no user can access another user's information.
 *
 * Data Structure: The data is organized hierarchically under the /users/{userId}
 * path. This top-level document stores the user's profile, and all related
 * entities, like 'purchases' and 'settlements', are stored in subcollections
 * within that user's document tree.
 *
 * Key Security Decisions:
 * - User Enumeration is Disallowed: Listing the top-level /users collection is
 *   explicitly forbidden to protect user privacy.
 * - Strict Path-Based Ownership: A user's authenticated UID must match the
 *   {userId} wildcard in the path to grant any access. This is the primary
 *   security mechanism.
 * - Default Deny: Any operation not explicitly granted is denied. There are no
 *   public collections.
 *
 * Denormalization for Authorization: To ensure fast and secure rule evaluation,
 * this ruleset relies on denormalized ownership fields. For example, a document
 * in the `/users/{userId}/purchases` collection must contain a `paidById` field
 * that mirrors the `{userId}` from the path. This avoids costly and slow `get()`
 * calls to parent documents, making authorization checks self-contained and
 * performant.
 *
 * Structural Segregation: The architecture uses separate collections for each
 * entity under a user's path (e.g., `purchases`, `settlements`). This structural
 * separation provides clear, secure boundaries for data access and simplifies
 * list queries, as a user listing their own purchases can never accidentally
 * access another user's data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for concise and readable rules.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Ensures an operation is performed by the owner on an existing document.
     * Prevents modifying or deleting documents that do not exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the user profile document being created has an 'id' field
     * that matches the document's path ID and the creator's auth UID.
     */
    function isCreatingValidUser(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Validates that a user's 'id' field remains unchanged during an update.
     */
    function isUpdatingValidUser() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that the purchase document being created has a 'paidById' field
     * that correctly links it to the user path it is nested under.
     */
    function isCreatingValidPurchase(userId) {
      return isOwner(userId) && request.resource.data.paidById == userId;
    }

    /**
     * Validates that the 'paidById' ownership link is immutable on update.
     */
    function isUpdatingValidPurchase() {
      return request.resource.data.paidById == resource.data.paidById;
    }

    /**
     * Validates that the settlement document being created has a 'fromUserId' field
     * that correctly links it to the user path it is nested under.
     */
    function isCreatingValidSettlement(userId) {
      return isOwner(userId) && request.resource.data.fromUserId == userId;
    }

    /**
     * Validates that the 'fromUserId' ownership link is immutable on update.
     */
    function isUpdatingValidSettlement() {
      return request.resource.data.fromUserId == resource.data.fromUserId;
    }

    /**
     * @description Rules for the User profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own user profile.
     * @allow (list) Any authenticated user can list users for split functionality.
     * @principle Enforces self-creation and ownership of a user's own profile document.
     * 
     * SECURITY NOTE: User listing is enabled to support expense splitting functionality.
     * This means all authenticated users can see the names and avatars of other users.
     * Consider implementing additional privacy controls if this is a concern for your use case.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isCreatingValidUser(userId);
      allow update: if isExistingOwner(userId) && isUpdatingValidUser();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for a user's purchase records.
     * @path /users/{userId}/purchases/{purchaseId}
     * @allow (create) An authenticated user creating a purchase record within their own data tree.
     * @deny (get) User 'A' attempting to read a purchase belonging to User 'B'.
     * @principle Restricts all access to a user's own data tree and validates relational integrity on write.
     */
    match /users/{userId}/purchases/{purchaseId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isCreatingValidPurchase(userId);
      allow update: if isExistingOwner(userId) && isUpdatingValidPurchase();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for a user's settlement records.
     * @path /users/{userId}/settlements/{settlementId}
     * @allow (list) An authenticated user listing their own settlement records.
     * @deny (create) User 'A' attempting to create a settlement record under User 'B's profile.
     * @principle Restricts all access to a user's own data tree and validates relational integrity on write.
     */
    match /users/{userId}/settlements/{settlementId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isCreatingValidSettlement(userId);
      allow update: if isExistingOwner(userId) && isUpdatingValidSettlement();
      allow delete: if isExistingOwner(userId);
    }
  }
}